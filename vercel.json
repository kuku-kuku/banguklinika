{
  "trailingSlash": true,
  "headers": [
    {
      "source": "/admin/config.yml",
      "headers": [{ "key": "Content-Type", "value": "text/yaml; charset=utf-8" }]
    },
    {
      "source": "/lt/:path*",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/ru/:path*",
